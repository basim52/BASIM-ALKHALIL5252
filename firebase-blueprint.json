{
  "entities": {
    "Project": {
      "title": "Script Project",
      "description": "Represents a generated script and its associated media assets.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The owner of the project." },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "videoStyle": { "type": "string" },
        "totalDuration": { "type": "number" },
        "script": { "type": "array" },
        "ideas": { "type": "array" },
        "prompt": { "type": "string" },
        "tags": { "type": "array" },
        "caption": { "type": "string" },
        "characterSheet": { "type": "string" },
        "type": { "type": "string" },
        "mediaResults": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "createdAt"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Stored user preferences and YouTube channel link status.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "youtubeLinked": { "type": "boolean" },
        "youtubeChannelId": { "type": "string" },
        "youtubeStats": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of archived script projects."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and settings."
    }
  }
}
